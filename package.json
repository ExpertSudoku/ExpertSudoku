{
  "name": "expertsudoku",
  "version": "1.0.32",
  "description": "ExpertSudoku - a daily Sudoku Discord Activity and standalone website (Medium/Expert/Hell difficulties)",
  "author": {
    "name": "Grant McLean",
    "email": "grant@mclean.net.nz",
    "url": "https://grantm.github.io/"
  },
  "license": "AGPLV3",
  "repository": "github:grantm/sudoku-web-app",
  "bugs": "https://github.com/grantm/sudoku-web-app/issues",
  "keywords": [
    "sudoku"
  ],
  "type": "module",
  "dependencies": {
    "@discord/embedded-app-sdk": "^2.4.0",
    "@resvg/resvg-wasm": "^2.6.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.9.9",
    "immutable": "4.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "save-svg-as-png": "1.4.17"
  },
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "check": "vite build && wrangler deploy --dry-run",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "dev:discord": "vite build && vite preview --port 3000",
    "lint": "eslint .",
    "preview": "npm run build && vite preview",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply expertsudoku-prod --local",
    "db:migrate:remote": "wrangler d1 migrations apply expertsudoku-prod --remote",
    "seed:generate": "node scripts/generate-puzzles.mjs",
    "seed:local": "wrangler d1 execute expertsudoku-prod --local --file=seed.sql",
    "seed:remote": "wrangler d1 execute expertsudoku-prod --remote --file=seed.sql"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.10",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "drizzle-kit": "^0.31.10",
    "vite": "^7.1.9",
    "wrangler": "^4.42.0"
  }
}
